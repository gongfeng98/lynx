+++ b/android/system_icu.cpp
@@ -0,0 +1,416 @@
+#include <android/log.h>
+#include <dirent.h>
+#include <dlfcn.h>
+#include <fcntl.h>
+#include <stdlib.h>
+#include <sys/mman.h>
