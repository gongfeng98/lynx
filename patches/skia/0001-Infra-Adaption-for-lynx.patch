+    SkMatrix44& postTranslate(SkScalar dx, SkScalar dy, SkScalar dz);
+
+    SkMatrix44& setScale(SkScalar sx, SkScalar sy, SkScalar sz);
+    SkMatrix44& preScale(SkScalar sx, SkScalar sy, SkScalar sz);
