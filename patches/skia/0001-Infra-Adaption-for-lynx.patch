+    inline void mapScalars(SkScalar vec[4]) const { this->mapScalars(vec, vec); }
+
+    friend SkVector4 operator*(const SkMatrix44& m, const SkVector4& src) {
+        SkVector4 dst;
+        m.mapScalars(src.fData, dst.fData);
+        return dst;
+    }
