+struct GenericFamily {
+    SkString familyName;                       // the specified family name of the font style set
+    std::shared_ptr<TypefaceSet> typefaceSet;  // the typeface set of the font style set
+    virtual ~GenericFamily() = default;
+};
+
+/*!
