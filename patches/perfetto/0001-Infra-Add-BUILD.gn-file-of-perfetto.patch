From 9cc0e63c1b122a0137b61715eb970fd15dee9ee9 Mon Sep 17 00:00:00 2001
From: KananSu <149131467+KananSu@users.noreply.github.com>
Date: Wed, 16 Jul 2025 15:32:14 +0800
Subject: [PATCH] [Infra] Add BUILD.gn file for perfetto

---
 sdk/BUILD.gn | 23 ++++++++++++++++++++++
 1 file changed, 23 insertions(+)
 create mode 100644 sdk/BUILD.gn

diff --git a/sdk/BUILD.gn b/sdk/BUILD.gn
new file mode 100644
index 0000000000..b46ed5cd31
--- /dev/null
+++ b/sdk/BUILD.gn
@@ -0,0 +1,22 @@
+# Copyright 2024 The Lynx Authors. All rights reserved.
+# Licensed under the Apache License Version 2.0 that can be found in the
+# LICENSE file in the root directory of this source tree.
+
+import("../../../config.gni")
+
+perfetto_header_files = [ "perfetto.h" ]
+
+perfetto_shared_sources = [ "perfetto.cc" ]
+
+config("allow_sign_compare") {
+  cflags = [ "-Wno-sign-compare" ]
+}
+
+source_set("perfetto") {
+  sources = perfetto_shared_sources + perfetto_header_files
+
+  # On some platfoms, cmsg = CMSG_NXTHDR(&msg_hdr, cmsg)) will cause build break:
+  #  comparison of integers of different signs: 'unsigned long' and 'long'
+  configs += [ ":allow_sign_compare" ]
+  deps = [ "//third_party/zlib" ]
+}
+
-- 
