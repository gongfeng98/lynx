diff --git a/src/hb-blob.cc b/src/hb-blob.cc
index 94ed50fd3..cec4bc782 100644
--- a/src/hb-blob.cc
+++ b/src/hb-blob.cc
@@ -100,9 +100,24 @@ hb_blob_create (const char        *data,
     }
   }
 
+  addFontMemoryUsage(length);
   return blob;
 }
 
+void addFontMemoryUsage(unsigned int size) {
+  if (size > 0)
+    FONT_SIZE_MEM += size;
+}
+
+void subFontMemoryUsage(unsigned int size) {
+  if (size > 0)
+    FONT_SIZE_MEM -= size;
+}
+
+unsigned int getHbFontMemoryUsage() {
+  return FONT_SIZE_MEM >= 0 ? FONT_SIZE_MEM : 0;
+}
+
 static void
 _hb_blob_destroy (void *data)
 {
