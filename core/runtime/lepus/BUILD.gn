import("../../../testing/test.gni")
import("../../Lynx.gni")
import("build.gni")

lynx_core_source_set("lepus") {
  sources = lynx_lepus_common_sources_path
  include_dirs = [ "//third_party/PrimTS/src" ]
  if (is_android) {
    if (!enable_just_lepusng) {
      sources += lynx_lepus_core_sources_path
    }
  } else {
    sources += lynx_lepus_core_sources_path
  }

  deps = []
  if (build_lepus_compile) {
    sources += lynx_lepus_compile_sources_path
    deps += [ "ir/llvh" ]
  }

  if (is_mac || is_linux) {
    deps += [ "../../../third_party/quickjs" ]
  } else if (is_ios) {
    deps += [ "../../../third_party/quickjs:quickjs_regexp" ]
  }
  public_deps = [
    "../../../base/src:base_values",
    "../../../third_party/rapidjson",
    "../../base",
    "../../parser",
    "../profile:profile_public_header",
    "tasks:tasks",
  ]

  if (is_mac) {
    exclude_configs = [ "//build/config/compiler:no_exceptions" ]
  }

  # The following macro is used for local debugging and prints the log to the console. please don't delete
  # if(is_test) {
  #   sources += [
  #     "ast_dump.h",
  #     "ast_dump.cc",
  #     "bytecode_print.h",
  #     "bytecode_print.cc",
  #     "ir/ir_dumper.cc",
  #     "ir/transformer/common/cfg_raw_viewer.cc",
  #     "ir/dialects/mir/mir_dumper.cc",
  #   ]
  #   defines = ["LEPUS_PC", "LEPUS_TEST"]
  # }
}

shared_library("lepus_shared") {
  sources = []
  deps = [
    ":lepus",
    "../../renderer/dom:dom",
  ]
}

