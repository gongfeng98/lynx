/**
 * The Lynx compiler options to set.
 *
 * @public
 */

{% if not export %}
export enum CompilerOptionAirMode {
  AIR_MODE_OFF = 0,
  AIR_MODE_TTML_WITHOUT_JS,
  AIR_MODE_NATIVE_SCRIPT,
  AIR_MODE_STRICT,
  AIR_MODE_FIBER,
}

{% endif %}
export interface CompilerOptions {
{% for option in options %}
{% if not export or (export and option.export)%}
  /**
   {% if option.desc %}
   * {{ option.desc }}
   *
   {% endif %}
    {% if option.support_platform %}
   * Supported platform: {{ option.support_platform | map('string') | join(", ") }}
   *
   {% endif %}
   {% if option.since %}
   * Since: LynxSDK {{ option.since }}
   *
   {% endif %}
   {% if option.js_default_value %}
   * @defaultValue {{ option.js_default_value }}
   *
   {% endif %}
   {% if option.deprecated %}
   * @deprecated {{ option.deprecated }}
   {% endif %}
   */
  {{ option.name }}?: {{ option.js_value_type }}

{% endif %}
{% endfor %}
}